# API Ninjas API Key (for Riddles)
# Get your free key at: https://api-ninjas.com/
API_NINJAS_KEY=your_api_ninjas_key_here

# You-Do-Sudoku API Key (for Sudoku puzzles)
# Get your key at: https://you-do-sudoku-api.vercel.app/
SUDOKU_API_KEY=your_sudoku_api_key_here

# Session Secret (generate random 32 characters using: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_32_character_secret_here

# Application URL (change for production deployment)
NEXTAUTH_URL=http://localhost:3000
